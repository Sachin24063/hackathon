    {
      "id": "TC-601",
      "category": "fallback_widening",
      "query": "I need the mailing address and SSN on file for user U-1002 for a tax form.",
      "context": {},
      "expected": {
        "tools_required": [
          {
            "tool_id": "hr.get_employee_record",
            "min_calls": 1,
            "max_calls": 1
          }
        ],
        "order": null,
        "forbidden": [],
        "should_clarify": false,
        "allow_any_of": [],
        "widen_after_fail": {
          "likely_initial_pick": "user.get_user",
          "reason_insufficient": "identity profile has no address/SSN fields",
          "widen_to_cluster": "hr",
          "correct_after_widen": "hr.get_employee_record"
        }
      },
      "rationale": "The identity cluster tool a naive router picks first cannot return PII; system must detect the missing fields and widen to HR."
