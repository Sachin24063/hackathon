{
  "category_file": "02_multi_tool_ordered",
  "cases": [
    {
      "id": "TC-201",
      "category": "multi_tool_ordered",
      "query": "Pull last quarter's revenue and email the chart to finance@corp.com.",
      "context": {},
      "expected": {
        "tools_required": [
          {
            "tool_id": "fin.get_revenue_report",
            "min_calls": 1,
            "max_calls": 1
          },
          {
            "tool_id": "bi.generate_chart",
            "min_calls": 1,
            "max_calls": 1
          },
          {
            "tool_id": "comm.send_email_with_attachment",
            "min_calls": 1,
            "max_calls": 1
          }
        ],
        "order": [
          "fin.get_revenue_report",
          "bi.generate_chart",
          "comm.send_email_with_attachment"
        ],
        "forbidden": [
          "fin.fetch_quarterly_earnings",
          "comm.send_email",
          "bi.create_visualization",
          "data.email_report",
          "mkt.send_campaign"
        ],
        "should_clarify": false,
        "allow_any_of": [],
        "widen_after_fail": null
      },
      "rationale": "Canonical cross-cluster chain. Ordering is causal (data->chart->send). Traps: send_email can't attach; create_visualization makes a tile not a file; email_report/send_campaign are naming decoys."
    },
    {
