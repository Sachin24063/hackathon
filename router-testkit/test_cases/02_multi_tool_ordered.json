            "min_calls": 1,
            "max_calls": 1
          },
          {
            "tool_id": "hr.submit_expense_reimbursement",
            "min_calls": 1,
            "max_calls": 1
          }
        ],
        "order": [
          "hr.lookup_employee",
          "hr.submit_expense_reimbursement"
        ],
        "forbidden": [
          "hr.get_employee_record"
        ],
        "should_clarify": false,
        "allow_any_of": [],
        "widen_after_fail": null
