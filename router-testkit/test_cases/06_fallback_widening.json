    {
      "id": "TC-602",
      "category": "fallback_widening",
      "query": "Attach the latest signed contract PDF to an email to legal@corp.com.",
      "context": {},
      "expected": {
        "tools_required": [
          {
            "tool_id": "legal.get_contract",
            "min_calls": 1,
            "max_calls": 1
          },
          {
            "tool_id": "comm.send_email_with_attachment",
            "min_calls": 1,
            "max_calls": 1
          }
        ],
        "order": [
          "legal.get_contract",
          "comm.send_email_with_attachment"
        ],
        "forbidden": [],
        "should_clarify": false,
        "allow_any_of": [],
        "widen_after_fail": {
          "likely_initial_pick": "comm.send_email",
          "reason_insufficient": "send_email cannot carry an attachment",
          "widen_to_cluster": "communication",
          "correct_after_widen": "comm.send_email_with_attachment"
        }
      },
      "rationale": "If the router first routes plain send_email, the attach requirement fails; widening within the comm cluster surfaces the attachment-capable variant."
    },
